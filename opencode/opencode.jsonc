{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "provider": {
    "anthropic": {
      "models": {
        "claude-opus-4-6": {
          "limit": { "context": 200000, "output": 128000 },
        },
      },
    },
    "openai": {
      "models": {
        "gpt-5.4": {
          "limit": { "context": 200000, "output": 128000 },
        },
        "gpt-5.3-codex": {
          "limit": { "context": 200000, "output": 128000 },
        },
      },
    },
  },
  "permission": {
    "external_directory": {
      "~/github.com/**": "allow",
    },
    "edit": {
      "~/cf/stratus/**": "allow",
    },
    "question": "deny",
    "bash": {
      // Generic shell commands
      "cat *": "allow",
      "echo *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "ls": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "sg *": "allow",
      "rm *": "deny",
      "trash *": "ask",
      "which *": "allow",
      "whoami": "allow",

      // curl
      "curl -X DELETE *": "ask",
      "curl -X PATCH *": "ask",
      "curl -X POST *": "ask",
      "curl -X PUT *": "ask",

      // Git
      "git blame *": "allow",
      "git diff *": "allow",
      "git diff": "allow",
      "git log *": "allow",
      "git log": "allow",
      "git push *": "ask",
      "git push": "ask",
      "git show *": "allow",
      "git show": "allow",
      "git status *": "allow",
      "git status": "allow",

      // Github CLI
      "gh api --method DELETE *": "ask",
      "gh api --method PATCH *": "ask",
      "gh api --method POST *": "ask",
      "gh api --method PUT *": "ask",
      "gh api -X DELETE *": "ask",
      "gh api -X PATCH *": "ask",
      "gh api -X POST *": "ask",
      "gh api -X PUT *": "ask",
      "gh issue close *": "ask",
      "gh issue comment *": "ask",
      "gh issue create *": "ask",
      "gh issue edit *": "ask",
      "gh pr close *": "ask",
      "gh pr comment *": "ask",
      "gh pr create *": "ask",
      "gh pr merge *": "ask",
      "gh pr review *": "ask",

      // Gitlab CLI
      "glab mr note *": "ask",

      // agent-browser
      "agent-browser": "allow",
      "agent-browser *": "allow",
      "agent-browser auth *": "ask",
      "agent-browser state *": "ask",
      "agent-browser eval *": "ask",
      "agent-browser set credentials *": "ask",
      "agent-browser cookies *": "ask",
      "agent-browser download *": "ask",
      "agent-browser upload *": "ask",
      "agent-browser --allow-file-access *": "ask",
      "agent-browser open file://*": "ask",

      // npx agent-browser
      "npx agent-browser *": "ask",
      "npx -y agent-browser@* *": "ask",

      // Node.js / npm
      "bun install": "ask",
      "bun publish *": "deny",
      "bun publish": "deny",
      "npm install": "ask",
      "npm publish *": "deny",
      "npm publish": "deny",
      "pnpm install": "ask",
      "pnpm publish *": "deny",
      "pnpm publish": "deny",
      "yarn install": "ask",
      "yarn publish *": "deny",
      "yarn publish": "deny",
    },
  },
  "plugin": [
    "@plannotator/opencode@latest",
  ],
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--autoConnect"],
      "enabled": false,
    },
    "xcodebuild-mcp": {
      "type": "local",
      "command": ["npx", "-y", "xcodebuildmcp@latest", "mcp"],
      "enabled": false,
    },
  },
}
