#!/usr/bin/env bash
set -euo pipefail

# Setup git configuration
setup_git_config() {
  echo "Setting up git configuration..."

  # Check if ~/.gitconfig.local exists
  if [ ! -f ~/.gitconfig.local ]; then
    echo "Creating ~/.gitconfig.local..."
    echo "Please enter your git email address:"
    read -p "Email: " git_email
    cat >~/.gitconfig.local <<EOF
[user]
	email = $git_email
EOF
    echo "Created ~/.gitconfig.local with email: $git_email"
  else
    echo "${HOME}/.gitconfig.local already exists"
  fi

  # Add includes to ~/.gitconfig only if they don't already exist
  echo "Checking ~/.gitconfig for required includes..."

  # Check if shared config include exists
  if ! grep -q "path = ~/.dotfiles/git/gitconfig" ~/.gitconfig 2>/dev/null; then
    echo "Adding shared git config include..."
    git config --global include.path ~/.dotfiles/git/gitconfig
  else
    echo "Shared git config include already exists"
  fi

  # Check if local config include exists
  if ! grep -q "path = ~/.gitconfig.local" ~/.gitconfig 2>/dev/null; then
    echo "Adding local git config include..."
    git config --global include.path ~/.gitconfig.local
  else
    echo "Local git config include already exists"
  fi
}

setup_git_config

touch ~/.dotfiles/.localProfile

if [ ! -d ~/.oh-my-zsh ]; then
  echo 'installing oh-my-zsh'
  curl https://raw.github.com/robbyrussell/oh-my-zsh/master/tools/install.sh -fsSL | sh
else
  echo 'oh-my-zsh already installed'
fi

echo 'copying dotfiles to user directory'
cp ~/.dotfiles/.zshrc ~/.zshrc

# Ensure parent directories exist before creating symlinks
mkdir -p ${HOME}/.config ${HOME}/.nvm ${HOME}/.tmux/plugins

ln -sf ${HOME}/.dotfiles/karabiner ${HOME}/.config/karabiner
ln -sf ${HOME}/.dotfiles/raycast ${HOME}/raycast
ln -sf ${HOME}/.dotfiles/lazygit ${HOME}/.config/lazygit
ln -sf ${HOME}/.dotfiles/nvm/default-packages ${HOME}/.nvm/default-packages
ln -sf ${HOME}/.dotfiles/.nirc ${HOME}/.nirc
ln -sf ${HOME}/.dotfiles/ghostty ${HOME}/.config/ghostty
ln -sf ${HOME}/.dotfiles/.claude ${HOME}/.claude
ln -sf ${HOME}/.dotfiles/opencode ${HOME}/.config/opencode
ln -sf ${HOME}/.dotfiles/worktrunk ${HOME}/.config/worktrunk
ln -sf ${HOME}/.dotfiles/alacritty ${HOME}/.config/alacritty
ln -sf ${HOME}/.dotfiles/nvim ${HOME}/.config/nvim
ln -sf ${HOME}/.dotfiles/config/lumen ${HOME}/.config/lumen

# Setup tmux
if [ ! -d ~/.tmux/plugins/tpm ]; then
  git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
else
  echo 'tpm already installed'
fi
ln -sf ${HOME}/.dotfiles/.tmux.conf ${HOME}/.tmux.conf

cd ~/.dotfiles

# Install Homebrew if not present, and ensure it's in PATH
if ! command -v brew &>/dev/null; then
  echo 'installing Homebrew...'
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew bundle
